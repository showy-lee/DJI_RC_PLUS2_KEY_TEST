<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="4dp"
            android:text="DJI RC Plus 2 Key Test"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/tv_connection_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MSDK: not registered"
                android:textColor="#FF0000"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_tab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:text="ESP32"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="4dp"
            android:background="#CCCCCC" />

        <TextView
            style="@style/SectionTitle"
            android:text="Sticks" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="2dp">

                <TextView
                    style="@style/GroupTitle"
                    android:text="Left stick" />

                <TextView
                    android:id="@+id/tv_left_horizontal"
                    style="@style/StatusText"
                    android:text="Horizontal: 0" />

                <TextView
                    android:id="@+id/tv_left_vertical"
                    style="@style/StatusText"
                    android:text="Vertical: 0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="2dp">

                <TextView
                    style="@style/GroupTitle"
                    android:text="Right stick" />

                <TextView
                    android:id="@+id/tv_right_horizontal"
                    style="@style/StatusText"
                    android:text="Horizontal: 0" />

                <TextView
                    android:id="@+id/tv_right_vertical"
                    style="@style/StatusText"
                    android:text="Vertical: 0" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="4dp"
            android:background="#CCCCCC" />

        <TextView
            style="@style/SectionTitle"
            android:text="DJI SDK buttons" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="2dp">

                <TextView
                    android:id="@+id/tv_shutter_button"
                    style="@style/StatusText"
                    android:text="Shutter: UP" />

                <TextView
                    android:id="@+id/tv_shutter_long_press"
                    style="@style/StatusText"
                    android:text="Shutter long: UP" />

                <TextView
                    android:id="@+id/tv_record_button"
                    style="@style/StatusText"
                    android:text="Record: UP" />

                <TextView
                    android:id="@+id/tv_gohome_button"
                    style="@style/StatusText"
                    android:text="Go Home: UP" />

                <TextView
                    android:id="@+id/tv_pause_button"
                    style="@style/StatusText"
                    android:text="Pause: UP" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="2dp">

                <TextView
                    android:id="@+id/tv_auth_led_button"
                    style="@style/StatusText"
                    android:text="Auth LED: UP" />

                <TextView
                    android:id="@+id/tv_custom_button1"
                    style="@style/StatusText"
                    android:text="C1: UP" />

                <TextView
                    android:id="@+id/tv_custom_button2"
                    style="@style/StatusText"
                    android:text="C2: UP" />

                <TextView
                    android:id="@+id/tv_custom_button3"
                    style="@style/StatusText"
                    android:text="C3: UP" />

                <TextView
                    android:id="@+id/tv_flight_mode_switch"
                    style="@style/StatusText"
                    android:text="Flight mode switch: unknown" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_rc_button_event"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:text="RC event pro: none"
            android:textColor="#333333"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_camera_focus_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:text="Camera focus: none"
            android:textColor="#333333"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_camera_focus_target_event"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:text="Focus event: none"
            android:textColor="#333333"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_camera_triggering_shutter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:text="Camera shutter: UP"
            android:textColor="#333333"
            android:textSize="10sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="4dp"
            android:background="#CCCCCC" />

        <TextView
            style="@style/SectionTitle"
            android:text="Dials" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_left_dial"
                style="@style/StatusText"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Left dial: 0" />

            <TextView
                android:id="@+id/tv_right_dial"
                style="@style/StatusText"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Right dial: 0" />

            <TextView
                android:id="@+id/tv_scroll_wheel"
                style="@style/StatusText"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Scroll wheel: 0" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="4dp"
            android:background="#CCCCCC" />

        <TextView
            style="@style/SectionTitle"
            android:text="Five-way" />

        <TextView
            android:id="@+id/tv_five_dimension"
            style="@style/StatusText"
            android:text="Five-way: idle" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="4dp"
            android:background="#CCCCCC" />

        <TextView
            style="@style/SectionTitle"
            android:text="Physical KeyEvent monitor" />

        <TextView
            android:id="@+id/tv_physical_last_event"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:text="Last event: none"
            android:textColor="#333333"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_physical_motion_event"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:text="Motion: none"
            android:textColor="#333333"
            android:textSize="10sp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:paddingTop="2dp">

            <TextView
                android:id="@+id/tv_physical_button1"
                style="@style/PhysicalKeyText" />

            <TextView
                android:id="@+id/tv_physical_button2"
                style="@style/PhysicalKeyText" />

            <TextView
                android:id="@+id/tv_physical_button3"
                style="@style/PhysicalKeyText" />

            <TextView
                android:id="@+id/tv_physical_button4"
                style="@style/PhysicalKeyText" />

            <TextView
                android:id="@+id/tv_physical_button5"
                style="@style/PhysicalKeyText" />

            <TextView
                android:id="@+id/tv_physical_button6"
                style="@style/PhysicalKeyText" />

            <TextView
                android:id="@+id/tv_physical_button7"
                style="@style/PhysicalKeyText" />

            <TextView
                android:id="@+id/tv_physical_button8"
                style="@style/PhysicalKeyText" />

            <TextView
                android:id="@+id/tv_physical_button9"
                style="@style/PhysicalKeyText" />

            <TextView
                android:id="@+id/tv_physical_button10"
                style="@style/PhysicalKeyText" />

            <TextView
                android:id="@+id/tv_physical_button11"
                style="@style/PhysicalKeyText" />

            <TextView
                android:id="@+id/tv_physical_button12"
                style="@style/PhysicalKeyText" />
        </GridLayout>

        <TextView
            android:id="@+id/tv_physical_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:text="Recent events will appear here."
            android:textColor="#555555"
            android:textSize="9sp" />
    </LinearLayout>
</ScrollView>
